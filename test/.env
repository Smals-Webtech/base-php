#!/bin/bash
# shellcheck disable=SC2034

COMPOSE_PROJECT_NAME=base-php

#
# MySQL / MariaDB configuration
#
MARIADB_DB_DRIVER="mysql"
MARIADB_DB_HOST="mariadb"
MARIADB_DB_PORT="3306"
MARIADB_DB_USER="example"
MARIADB_DB_PASSWORD="example"
MARIADB_DB_NAME="example"
MARIADB_ROOT_DB_PASSWORD="p4ssw0rd"

#
# Elasticsearch
#

ES_CLT_USERNAME="bats_clt"
ES_CLT_PASSWORD="changeme"
ES_PRD_USERNAME="bats_prd"
ES_PRD_PASSWORD="changeme"
ES_KIBANA_USERNAME="kibana_system"
ES_KIBANA_PASSWORD="changeme"

#
# Kibana
#

XPACK_ENCRYPTEDSAVEDOBJECTS_ENCRYPTIONKEY="OwW927ytL4GUrz86aVRjnFOuLUtSUJ1T"
XPACK_REPORTING_ENCRYPTIONKEY="0qG1afICHL92396KYJRppe4TSY7Gda39"
XPACK_SECURITY_ENCRYPTIONKEY="Uv34b8aUtRtEfWzy9p8pMd414Kn1Tzfb"

#
# Docker Compose
#

CONTAINER_NETWORK_NAME="demo"

# ------ #

#
# PHP / Application configuration
#
BATS_PHP_FPM_MAX_CHILDREN="4"
BATS_PHP_FPM_REQUEST_MAX_MEMORY_IN_MEGABYTES="128"
BATS_CONTAINER_HEAP_PERCENT="0.80"
BATS_VARNISH_VCL_CONF_CUSTOM="/opt/etc/varnish/bats.vcl"
BATS_PHP_VERSION="8.5.3"
BATS_AWS_CLI_VERSION="${AWS_CLI_VERSION:-2.32.7}"

#
# Containers configuration
#
BATS_CONTAINER_NETWORK_NAME="demo"


BATS_UID="$(id -u):$(id -g)"


