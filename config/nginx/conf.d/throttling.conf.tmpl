# This configuration file is autogenerated by the container startup script

# --- 1. Trusted IP Whitelist ---
# Maps client IP addresses to a 'trusted' status.
# Using 'geo' block for optimized CIDR prefix matching.
geo $is_trusted_ip {
    default 1; # By default, IP is NOT trusted (1)
    
    {{- range (datasource "cidrs") }}
    {{ . }} 0;
    {{- end }}

}

# --- 2. Bot Detection (User-Agent based) ---
# Identifies automated traffic via Regex matching.
map $http_user_agent $is_bot_candidate {
    default 0;

    {{- range (datasource "agents") }}
    {{ . }} 1;
    {{- end }}

}

# --- 3. Final Enforcement Logic ---
# Combines IP whitelist and Bot detection.
# Logic: If IP is trusted (0), then $is_bot is 0. 
# Otherwise, it takes the value of the bot detection.
map $is_trusted_ip$is_bot_candidate $is_bot {
    "~^0"     0; # Trusted IP: ignore bot status
    "~^11"    1; # Non-trusted IP AND identified as bot
    default   0; # Everything else (Non-trusted IP but human-like)
}

# --- Bot-Specific Rate Limiting Logic ---
# Conditional mapping: Only requests identified as bots are assigned a tracking key ($remote_addr).
# Empty strings are ignored by Nginx's rate-limiting module, effectively bypassing the limit for non-bots.
map $is_bot $bot_limit_key {
    0 "";
    1 $remote_addr;
}

# Bot enforcement zone: Strict policy (e.g., 1r/m) to mitigate aggressive crawling.
limit_req_zone $bot_limit_key zone=bot_limit:{{ $.Env.NGINX_SOFT_THROTTLE_BOTS_ZONE_SIZE }} rate={{ $.Env.NGINX_SOFT_THROTTLE_BOTS_ZONE_RATE }};

# --- Global Protection Zone ---
# Standard rate limiting applied to all incoming traffic to protect upstream services (e.g., PHP-FPM).
# Note: A zone size of 20m can track approximately 320k unique IP addresses.
limit_req_zone $remote_addr zone=global_limit:{{ $.Env.NGINX_SOFT_THROTTLE_GLOBAL_ZONE_SIZE }} rate={{ $.Env.NGINX_SOFT_THROTTLE_GLOBAL_ZONE_RATE }};

# --- Dry Run Mode (Staging/Calibration) ---
# When enabled, Nginx logs rate-limiting events but does not reject requests.
# Use this to calibrate 'rate' and 'burst' values without impacting real users.
limit_req_dry_run {{ $.Env.NGINX_SOFT_THROTTLE_DRY_RUN_ENABLED }};

# Custom HTTP status code for requests exceeding the rate limit.
# Typically set to 429 (Too Many Requests) or 503 (Service Unavailable).
limit_req_status {{ $.Env.NGINX_SOFT_THROTTLE_STATUS_CODE }};
